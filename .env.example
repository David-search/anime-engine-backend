# Copy to .env (gitignored). Compose reads it for ${VAR} substitution.
CONTAINER_NAME=anime-backend
BACKEND_HOST_PORT=8000          # local 8000 ; server 8008 (vast public 43577)
CORS_ORIGINS=*

# Data stores. On the server use in-network names
# (mongodb:27017, elasticsearch:9200); locally use the external
# 70.30.158.46 ports (43829 / 43505). db anime_db, index anime.
MONGO_URI=
ELASTIC_URL=
ELASTIC_USER=elastic
ELASTIC_PASSWORD=
ELASTIC_INDEX=anime

# Auth
JWT_SECRET=                     # HS256 signing secret for JWTs (set a strong random value)
GOOGLE_CLIENT_ID=              # Google OAuth client id; backend verifies the id token's aud against it
